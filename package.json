{
  "name": "claude-web",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "daemon",
    "frontend"
  ],
  "scripts": {
    "postinstall": "find node_modules/node-pty/prebuilds -name 'spawn-helper' -exec chmod +x {} \\; 2>/dev/null || true",
    "build": "npm run build --workspace=frontend",
    "dev": "concurrently --names daemon,vite --prefix-colors cyan,magenta \"node daemon/src/index.js\" \"npm run dev --workspace=frontend\"",
    "daemon": "node daemon/src/index.js"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
